{
  "expo": {
    "name": "Control PV",
    "slug": "control-pv-mobile",
    "scheme": "pvnpvv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Se usa la cámara para fotografiar los comprobantes de pago QR.",
        "NSPhotoLibraryUsageDescription": "Se accede a la galería para adjuntar comprobantes de pago QR."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.klarenssorganization.controlpvmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Se accede a la galería para adjuntar comprobantes de pago QR.",
          "cameraPermission": "Se usa la cámara para fotografiar los comprobantes de pago QR."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26e47ec8-be2e-43e5-9634-ed58a253417f"
      }
    },
    "owner": "klarenss-organization"
  }
}
